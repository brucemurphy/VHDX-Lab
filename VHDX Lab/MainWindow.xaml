<Window x:Name="VHDX_Lab" x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation/shell"
        mc:Ignorable="d"
        Title="VHDX Lab"
        Height="768" 
        Width="1280"
        WindowStyle="SingleBorderWindow"
        Background="Black">
    
    <Window.Resources>
        <Style TargetType="{x:Type Window}">
           
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- Footer with Progress Panel and Activity Light -->
        <Border x:Name="FooterB" Width="902" Height="86" Background="#BF000000" 
                HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                Margin="0,0,0,0" CornerRadius="5,5,0,0">
            <Canvas x:Name="FooterGrid" Width="902" Height="86" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <!-- Heading Text -->
                <TextBlock x:Name="HeadingTextBlock"
                           Foreground="#FFCCCCCC"
                           FontSize="22"
                           Canvas.Left="31"
                           Canvas.Top="16"/>
                
                <!-- Copyright Text -->
                <TextBlock x:Name="CopyrightTextBlock"
                           Foreground="#CCC"
                           TextWrapping="Wrap"
                           Canvas.Left="31"
                           Canvas.Top="50"
                           Width="600"/>

                <!-- DISM Activity Light - Fixed Position -->
                <Ellipse x:Name="DismActivityLight"
                         Width="18" Height="18"
                         Fill="#333"
                         Stroke="#555"
                         StrokeThickness="1"
                         Cursor="Hand"
                         Canvas.Right="20"
                         Canvas.Top="34"
                         ToolTip="DISM Activity"/>

                <!-- Progress Panel - Fixed Position and Size -->
                <StackPanel x:Name="ProgressPanel"
                            Orientation="Vertical"
                            Canvas.Right="50"
                            Canvas.Top="16"
                            Width="230">
                    <!-- Main progress text (big) -->
                    <TextBlock x:Name="MountSizeProgressText"
                               FontSize="22"
                               Foreground="#FFE2E2E2"
                               TextAlignment="Right"
                               TextTrimming="None"
                               TextWrapping="NoWrap"
                               Width="230"/>
                    
                    <!-- Detail line (smaller) -->
                    <TextBlock x:Name="MountSizeProgressTextDetail"
                               Margin="0,4,0,0"
                               Foreground="#FFE2E2E2"
                               TextAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Width="230"/>
                </StackPanel>
            </Canvas>
        </Border>

        <!-- BCDEntrys ListBox -->
        <Border Width="220" Height="545" Background="#BF000000" CornerRadius="5" 
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="84,76,0,0">
            <ListBox x:Name="BCDEntrys" d:ItemsSource="{d:SampleData ItemCount=5}" 
                     Background="Transparent" BorderThickness="0" Foreground="#FFFAFAFA"/>
        </Border>

        <!-- GUIDDetail TextBox -->
        <Border Width="575" Height="545" Background="#BF000000" CornerRadius="5" 
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="332,76,0,0">
            <TextBox x:Name="GUIDDetail" Background="Transparent" BorderThickness="0" Foreground="#FFFAFAFA" 
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" 
                     Padding="10" FontFamily="Consolas"/>
        </Border>

        <!-- Add VHDX Button -->
        <Border Width="125" Height="32" Background="#BF000000" CornerRadius="5" 
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="912,76,0,0">
            <Button x:Name="AddVHDXButton" Content="Add VHDX" Background="Transparent" BorderThickness="0" 
                    Foreground="#FFFAFAFA" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="{x:Type Button}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3FFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5FFFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Border>

        <!-- Delete Entry Button -->
        <Border Width="125" Height="32" Background="#BF000000" CornerRadius="5" 
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="912,113,0,0">
            <Button x:Name="DeleteEntryButton" Content="Delete Entry" Background="Transparent" BorderThickness="0" 
                    Foreground="#FFFAFAFA" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="{x:Type Button}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3FFF0000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5FFF0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Border>
    </Grid>
</Window>
